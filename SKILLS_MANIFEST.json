  "integration_decisions": [
    {
      "topic": "ftshare-market-data vs yc-buy-selector",
      "decision": "不合并技能；FTShare作为数据层，YC-buy作为策略层，在src/skill_lab中用provider接口衔接。",
      "reason": "数据接口变化和策略迭代节奏不同，分层可减少耦合并方便替换数据源。"
    },
    {
      "topic": "watchlist-tracker",
      "decision": "作为独立tracking领域，而不是并入stock-selection。",
      "reason": "选股是发现候选，tracking是持续观察与复盘，未来会覆盖板块、主题、ETF、指数和交易策略，不应只绑定单次选股。"
    }
